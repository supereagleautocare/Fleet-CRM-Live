# ════════════════════════════════════════════════════════
# FLEET CRM — Environment Variables
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# Security — CHANGE THIS to a long random string before going live!
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=change-this-to-a-random-secret-string-before-going-live
JWT_EXPIRES=8h

# Frontend URL (for CORS — set this to your frontend URL in production)
FRONTEND_URL=http://localhost:3000

# Google Contacts OAuth (fill in after setting up Google Cloud project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# Anthropic API — required for Fleet Finder AI search
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
